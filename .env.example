# ── Application ───────────────────────────────────────────────────────────────
ENV=development

# ── AI Keys ───────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
POSTGRES_DB=kgdb
POSTGRES_USER=kguser
POSTGRES_PASSWORD=kgpassword
DATABASE_URL=postgresql+asyncpg://kguser:kgpassword@postgres:5432/kgdb

# ── Neo4j (planned for later steps) ───────────────────────────────────────────
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4jpassword

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000"]

# ── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000/api
