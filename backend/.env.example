ENV=development
APP_NAME=Ontology Graph Studio
APP_VERSION=0.1.0

# AI keys
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://kguser:kgpassword@localhost:5432/kgdb

# Neo4j (planned for later steps)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4jpassword

# CORS (comma-separated list)
CORS_ORIGINS=["http://localhost:3000"]
